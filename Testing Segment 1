# Define Segment 1 for any alpha. This has been verified with a SolidWorks model.
c_0_1 = np.array([[0],
                  [0],
                  [0]])
c_0_2 = np.array([[w],
                  [0],
                  [0]])
c_0_3 = np.array([[w+h*np.cos(alpha)],
                  [0],
                  [h*np.sin(alpha)]])
c_0_4 = np.array([[h*np.cos(alpha)],
                  [0],
                  [h*np.sin(alpha)]])
c_1_1 = np.array([[0],
                  [L_1],
                  [0]])
c_1_2 = np.array([[w],
                  [L_1 - w/np.tan(gamma_1)],
                  [0]])
c_1_3 = np.array([[w + h*np.cos(alpha)],
                  [L_1 - w/np.tan(gamma_1) - h/np.tan(theta_1)],
                  [h*np.sin(alpha)]])
c_1_4 = np.array([[h*np.cos(alpha)],
                  [L_1 - h/np.tan(theta_1)],
                  [h*np.sin(alpha)]])

